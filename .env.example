# ============================================
# JointSettle - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# For Vercel deployment, set these in the Vercel dashboard.
# ============================================

# === Database (PostgreSQL) ===
# Required. Use Vercel Postgres, Neon, Supabase, or your own provider.
# Prisma uses DATABASE_URL (with connection pooling if available).
DATABASE_URL=postgresql://postgres:password@localhost:5432/jointsettle
POSTGRES_URL_NON_POOLING=postgresql://postgres:password@localhost:5432/jointsettle

# === App ===
# Required. Must match your deployment URL (e.g. https://jointsettle.vercel.app)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# === Optional: AI Receipt Scanning ===
OPENAI_API_KEY=
NEXT_PUBLIC_ENABLE_RECEIPT_EXTRACT=false

# === Optional: AI Category Extraction ===
NEXT_PUBLIC_ENABLE_CATEGORY_EXTRACT=false

# === Optional: S3 File Uploads ===
NEXT_PUBLIC_ENABLE_EXPENSE_DOCUMENTS=false
S3_UPLOAD_KEY=
S3_UPLOAD_SECRET=
S3_UPLOAD_BUCKET=
S3_UPLOAD_REGION=
S3_UPLOAD_ENDPOINT=

# === Optional: Stripe Donations ===
STRIPE_DONATION_LINK=

# === Optional: Plausible Analytics ===
PLAUSIBLE_DOMAIN=

# === Optional: Resend Emails ===
RESEND_API_KEY=
