# ============================================================
# JointSettle – .gitignore
# Stack: Next.js · TypeScript · Prisma (PostgreSQL) · Docker
# ============================================================

# ─── Dependencies ───────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Next.js build output ───────────────────────────────────
.next/
/out/

# ─── SWC compiler cache ─────────────────────────────────────
.swc/

# ─── Production build ───────────────────────────────────────
/build/

# ─── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Testing ────────────────────────────────────────────────
/coverage/

# ─── Environment & secrets ──────────────────────────────────
# Ignore all env files …
.env
.env.*
*.env
# … but keep the committed example/template files
!.env.example
!container.env.example
# scripts/build.env is intentional (mock values for Docker build)
!scripts/build.env

# ─── Prisma ─────────────────────────────────────────────────
# Generated client is rebuilt on postinstall
prisma/generated/

# ─── Docker / local DB data ─────────────────────────────────
postgres-data/
container.env

# ─── Vercel ─────────────────────────────────────────────────
.vercel/

# ─── Logs ───────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── OS artifacts ───────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ─── Editor & IDE ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/

# ─── Security / certificates ────────────────────────────────
*.pem
*.key
*.p12
*.pfx

# ─── Python (utility scripts) ───────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# ─── Miscellaneous ──────────────────────────────────────────
*.tgz
*.tar.gz
dist/
tmp/
.tmp/
